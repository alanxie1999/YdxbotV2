{
    # 账号配置版本
    "version": "2.5.0",

    # Telegram 登录参数（必填）
    # api_id/api_hash 从 my.telegram.org 获取
    # session_name 对应 .session 文件名（不带后缀）
    "telegram": {
        "api_id": 12345678,
        "api_hash": "your_api_hash",
        "session_name": "your_session_name",
        "user_id": 1234567890
    },

    # 账号展示名称
    "account": {
        "name": "你的账号名",
        "description": "账号备注"
    },

    # 账号私有朱雀认证（必填）
    "zhuque": {
        "cookie": "socute=请填你的cookie",
        "x_csrf": "请填你的x_csrf"
    },

    # 管理员控制台（二选一，必配）
    "admin_console": {
        # 可选：telegram_id / telegram_bot
        "mode": "telegram_id",

        # 方案一：通过 Telegram chat id 管理（适合 me / 私聊 / 专用群）
        "telegram_id": {
            "chat_id": 1234567890
        },

        # 方案二：通过管理员专用 Bot 管理（适合每账号独立控制台）
        "telegram_bot": {
            "bot_token": "",
            "chat_id": "",
            # 可选：允许发命令的 Telegram 用户 ID 白名单
            "allowed_sender_ids": []
        }
    },

    # 通知渠道（只负责通知，不负责命令交互）
    "notification": {
        "channels": {
            "iyuu": {
                "enable": false,
                "url": "",
                "token": ""
            },
            "telegram_notify_bot": {
                "enable": false,
                "bot_token": "",
                "chat_id": ""
            }
        }
    },

    # AI 配置（OpenAI 兼容；可按账号独立设置）
    "ai": {
        "enabled": true,
        "api_keys": [
            "sk-your-openai-compatible-key"
        ],
        "base_url": "https://api.openai.com/v1",
        "timeout": 30,
        "max_retries": 3,
        # 模型链异常时是否继续走统计兜底下注
        "enable_stat_fallback_bet": true,
        "models": {
            "1": {
                "model_id": "gpt-4o-mini",
                "enabled": true
            }
        },
        "fallback_chain": [
            "1"
        ]
    }
}
